<script>
    window.toggleDebug = function() {
        const term = document.getElementById('debug-terminal');
        term.style.display = (term.style.display === 'none' || term.style.display === '') ? 'block' : 'none';
    };
    const term = document.getElementById('debug-terminal');
    window.onerror = function(msg, url, line) {
        term.style.display = 'block';
        term.innerHTML += `<div style="color:red">! ERROR: ${msg} @ ${line}</div>`;
    };
    const originalLog = console.log;
    console.log = function(msg) {
        if(term) { term.innerHTML += `<div>> ${msg}</div>`; term.scrollTop = term.scrollHeight; }
        originalLog.apply(console, arguments);
    };
</script>

