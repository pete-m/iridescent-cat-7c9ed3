    <div>[DEBUG LOG START]</div>
</div>

<script>
    // Force-capture all errors immediately
    window.onerror = function(msg, url, line) {
        const t = document.getElementById('debug-terminal');
        t.innerHTML += `<div style="color:#ff4444;">! ERROR: ${msg} <br> at ${url}:${line}</div>`;
        return false;
    };
    
    // Mirror standard logs
    const termElement = document.getElementById('debug-terminal');
    const oldLog = console.log;
    console.log = function(m) {
        termElement.innerHTML += `<div>> ${m}</div>`;
        termElement.scrollTop = termElement.scrollHeight;
        oldLog.apply(console, arguments);
    };
</script>

